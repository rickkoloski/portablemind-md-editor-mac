#!/bin/bash
# md-editor — thin CLI wrapper over the md-editor:// URL scheme.
#
# Usage:
#   md-editor                 # launch/activate the app (use File →
#                             #   Open Folder… from inside)
#   md-editor <file>          # open file in a tab (focus if already
#                             #   open); launch app if not running
#   md-editor <directory>     # set as workspace root; launch app
#                             #   if not running
#
# This script does not embed any command semantics of its own; it
# computes the absolute path, URL-encodes it, composes an
# md-editor:// URL, and hands it to `open`. macOS launches MdEditor
# if it is not already running.
#
# Engineering-standards §2.4: all external-entry handling happens
# inside Sources/CommandSurface/. This script is a courier, not a
# handler.

set -euo pipefail

BUNDLE_ID="ai.portablemind.md-editor"

target="${1:-}"
if [[ -z "$target" ]]; then
  # No argument → launch (or activate) the app. `open -b` uses the
  # bundle identifier registered in LaunchServices; works for both
  # dev builds (registered on first launch by Xcode) and installed
  # builds.
  open -b "$BUNDLE_ID"
  exit 0
fi

# D9: parse trailing `:line` or `:line:column` suffix (vim/grep style).
# Only strip the suffix if the literal path doesn't exist but the
# stripped form does — preserves behavior for the rare macOS file
# whose name contains an actual colon.
line=""
column=""
if [[ ! -e "$target" ]]; then
  if [[ "$target" =~ ^(.+):([0-9]+):([0-9]+)$ ]]; then
    candidate="${BASH_REMATCH[1]}"
    candidate_line="${BASH_REMATCH[2]}"
    candidate_col="${BASH_REMATCH[3]}"
    if [[ -e "$candidate" ]]; then
      target="$candidate"
      line="$candidate_line"
      column="$candidate_col"
    fi
  elif [[ "$target" =~ ^(.+):([0-9]+)$ ]]; then
    candidate="${BASH_REMATCH[1]}"
    candidate_line="${BASH_REMATCH[2]}"
    if [[ -e "$candidate" ]]; then
      target="$candidate"
      line="$candidate_line"
    fi
  fi
fi

if [[ ! -e "$target" ]]; then
  echo "md-editor: no such file or directory: $target" >&2
  exit 1
fi

absolute="$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"
encoded="$(python3 -c 'import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=""))' "$absolute")"

if [[ -d "$absolute" ]]; then
  open "md-editor://open-folder?path=$encoded"
else
  url="md-editor://open?path=$encoded&tab=existing"
  if [[ -n "$line" ]]; then
    url="${url}&line=${line}"
  fi
  if [[ -n "$column" ]]; then
    url="${url}&column=${column}"
  fi
  open "$url"
fi
