#!/bin/bash
# md-editor — thin CLI wrapper over the md-editor:// URL scheme.
#
# Usage:
#   md-editor                            # launch/activate the app
#   md-editor <file>                     # open file in a tab
#   md-editor <directory>                # set as workspace root
#   md-editor <file>:<line>              # open + caret at line (D9)
#   md-editor <file>:<line>:<col>        # open + caret at line:col (D9)
#
#   Flags (D11, composable with any of the above, or used standalone):
#     --line-numbers=on|off              # set line-number visibility
#
#   Flags (D30):
#     --session=<id>                     # register session interest on
#                                          the opened tab. If omitted,
#                                          the shim falls back to
#                                          ${MD_EDITOR_SESSION_ID:-$TERM_SESSION_ID}.
#                                          Pass --session="" to suppress
#                                          the fallback and open as a
#                                          manual-open (no interest).
#     --release [<file>|--all]           # release the named session's
#                                          interest in <file>, or in
#                                          every open tab.
#                                          Requires --session=<id>.
#
# Engineering-standards §2.4: all external-entry handling happens
# inside Sources/CommandSurface/. This script is a courier, not a
# handler. **Discipline:** state-setter flags pass through the
# declared value (on/off). Never introduce a `--toggle` form.

set -euo pipefail

BUNDLE_ID="ai.portablemind.md-editor"

# D11 + D30: parse flags (any order), leaving one positional arg.
line_numbers=""
session_arg=""
session_explicit=0
release_action=0
release_all=0
positional=()
for arg in "$@"; do
  case "$arg" in
    --line-numbers=*)
      line_numbers="${arg#--line-numbers=}"
      ;;
    --session=*)
      session_arg="${arg#--session=}"
      session_explicit=1
      ;;
    --release)
      release_action=1
      ;;
    --all)
      release_all=1
      ;;
    --)
      : # separator — future
      ;;
    -*)
      echo "md-editor: unknown flag: $arg" >&2
      exit 2
      ;;
    *)
      positional+=("$arg")
      ;;
  esac
done

# D30: resolve effective session id.
# Precedence: explicit --session=<id> (including empty string to opt
# out) > MD_EDITOR_SESSION_ID > TERM_SESSION_ID. Empty string anywhere
# in this chain means "no session" — register as manual-open.
if [[ $session_explicit -eq 1 ]]; then
  session_id="$session_arg"
else
  session_id="${MD_EDITOR_SESSION_ID:-${TERM_SESSION_ID:-}}"
fi

# D30: --release action. Independent of the open/set-view flow.
if [[ $release_action -eq 1 ]]; then
  if [[ -z "$session_id" ]]; then
    echo "md-editor: --release requires --session=<id>" >&2
    exit 2
  fi
  encoded_session="$(python3 -c 'import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=""))' "$session_id")"
  if [[ $release_all -eq 1 ]]; then
    open "md-editor://release?session=${encoded_session}&all=true"
    exit 0
  fi
  if [[ ${#positional[@]} -eq 0 ]]; then
    echo "md-editor: --release requires either --all or a file path" >&2
    exit 2
  fi
  if [[ ${#positional[@]} -gt 1 ]]; then
    echo "md-editor: --release accepts one file path: ${positional[*]}" >&2
    exit 2
  fi
  target="${positional[0]}"
  if [[ ! -e "$target" ]]; then
    echo "md-editor: --release target does not exist: $target" >&2
    exit 1
  fi
  absolute="$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"
  encoded_path="$(python3 -c 'import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=""))' "$absolute")"
  open "md-editor://release?session=${encoded_session}&path=${encoded_path}"
  exit 0
fi

if [[ ${#positional[@]} -gt 1 ]]; then
  echo "md-editor: too many positional arguments: ${positional[*]}" >&2
  exit 2
fi
target="${positional[0]:-}"

# Compose view-state query param (for open/set-view URLs).
view_qs=""
if [[ -n "$line_numbers" ]]; then
  view_qs="&line_numbers=${line_numbers}"
fi

# D30: compose session query param.
session_qs=""
if [[ -n "$session_id" ]]; then
  encoded_session="$(python3 -c 'import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=""))' "$session_id")"
  session_qs="&session=${encoded_session}"
fi

if [[ -z "$target" ]]; then
  if [[ -n "$line_numbers" ]]; then
    # Standalone view-state set — no file/folder.
    open "md-editor://set-view?line_numbers=${line_numbers}"
    exit 0
  fi
  # Plain launch/activate.
  open -b "$BUNDLE_ID"
  exit 0
fi

# D9: parse trailing `:line` or `:line:column` suffix (vim/grep style).
# Only strip the suffix if the literal path doesn't exist but the
# stripped form does — preserves behavior for the rare macOS file
# whose name contains an actual colon.
line=""
column=""
if [[ ! -e "$target" ]]; then
  if [[ "$target" =~ ^(.+):([0-9]+):([0-9]+)$ ]]; then
    candidate="${BASH_REMATCH[1]}"
    candidate_line="${BASH_REMATCH[2]}"
    candidate_col="${BASH_REMATCH[3]}"
    if [[ -e "$candidate" ]]; then
      target="$candidate"
      line="$candidate_line"
      column="$candidate_col"
    fi
  elif [[ "$target" =~ ^(.+):([0-9]+)$ ]]; then
    candidate="${BASH_REMATCH[1]}"
    candidate_line="${BASH_REMATCH[2]}"
    if [[ -e "$candidate" ]]; then
      target="$candidate"
      line="$candidate_line"
    fi
  fi
fi

if [[ ! -e "$target" ]]; then
  echo "md-editor: no such file or directory: $target" >&2
  exit 1
fi

absolute="$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"
encoded="$(python3 -c 'import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=""))' "$absolute")"

if [[ -d "$absolute" ]]; then
  url="md-editor://open-folder?path=$encoded"
  open "$url"
else
  url="md-editor://open?path=$encoded&tab=existing${view_qs}${session_qs}"
  if [[ -n "$line" ]]; then
    url="${url}&line=${line}"
  fi
  if [[ -n "$column" ]]; then
    url="${url}&column=${column}"
  fi
  open "$url"
fi
